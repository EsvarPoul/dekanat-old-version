/etc/nginx/sites-available/default

server {
    listen 443 ssl http2;
    server_name dekanat.ntu.edu.ua;

    ssl_certificate     /etc/letsencrypt/live/dekanat.ntu.edu.ua/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/dekanat.ntu.edu.ua/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    # Сертифікаційний челендж Let’s Encrypt
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location ^~ /test/ {
        proxy_pass         http://127.0.0.1:8081;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # Ось тут було `return 301 …` — замінимо на проксі до Spring
    location / {
        proxy_pass         http://127.0.0.1:8080;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
}


server {
    if ($host = dekanat.ntu.edu.ua) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name dekanat.ntu.edu.ua;
    return 404; # managed by Certbot


}
